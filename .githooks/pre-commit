#!/usr/bin/env bash
#
# Pre-commit hook: 只檢查暫存區 (staged) 的 PHP 檔案
#   1. php -l  —— 基本語法錯誤
#   2. Laravel Pint —— 排版 (自動修正後重新 stage)
#
# 啟用方式 (僅需執行一次):
#   git config core.hooksPath .githooks
#
set -euo pipefail

RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[1;33m'
NC=$'\033[0m'

STAGED_PHP_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.php$' || true)

if [ -z "$STAGED_PHP_FILES" ]; then
    exit 0
fi

echo "${YELLOW}▶ pre-commit: 檢查 PHP 檔案...${NC}"

# --- 1. php -l (語法檢查) -----------------------------------------------------
SYNTAX_ERRORS=0
while IFS= read -r FILE; do
    [ -z "$FILE" ] && continue
    if ! php -l "$FILE" >/dev/null 2>&1; then
        echo "${RED}✗ PHP 語法錯誤:${NC} $FILE"
        php -l "$FILE" || true
        SYNTAX_ERRORS=$((SYNTAX_ERRORS + 1))
    fi
done <<< "$STAGED_PHP_FILES"

if [ "$SYNTAX_ERRORS" -gt 0 ]; then
    echo "${RED}✗ 發現 ${SYNTAX_ERRORS} 個 PHP 語法錯誤，已阻止 commit${NC}"
    exit 1
fi

# --- 2. Pint (排版) ----------------------------------------------------------
if [ ! -x vendor/bin/pint ]; then
    echo "${YELLOW}⚠ 找不到 vendor/bin/pint，略過排版檢查 (請先執行 composer install)${NC}"
    exit 0
fi

# 將暫存區的檔案清單以 null-delimited 傳給 pint，避免檔名含空白
echo "$STAGED_PHP_FILES" | xargs vendor/bin/pint -q

# 將 Pint 修正後的結果重新加回暫存區
echo "$STAGED_PHP_FILES" | xargs git add

echo "${GREEN}✔ pre-commit 檢查通過${NC}"
exit 0
